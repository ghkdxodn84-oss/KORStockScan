+def _normalize_stock_code(code) -> str:
+    raw = str(code or "").strip().upper().replace('.0', '')
+    if raw.endswith('_AL'):
+        raw = raw[:-3]
+    if raw.startswith('A') and len(raw) >= 7:
+        raw = raw[1:]
+    digits = ''.join(ch for ch in raw if ch.isdigit())
+    return digits[-6:].zfill(6) if digits else raw
+
