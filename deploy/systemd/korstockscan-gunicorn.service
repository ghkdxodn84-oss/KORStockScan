[Unit]
Description=KORStockScan Gunicorn Web App
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/KORStockScan
Environment="PYTHONPATH=/home/ubuntu/KORStockScan"
ExecStart=/home/ubuntu/KORStockScan/.venv/bin/gunicorn -w 2 -b 127.0.0.1:5000 src.web.app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
